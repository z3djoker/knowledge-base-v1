generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Customer {
  id            String    @id @default(uuid()) @db.Uuid
  name          String
  code          String?   @unique
  industry      String?
  description   String?
  status        String    @default("active")
  extraMetadata Json?     @map("extra_metadata") @db.JsonB
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  projects      Project[]

  @@index([status])
  @@map("customers")
}

model Project {
  id                String          @id @default(uuid()) @db.Uuid
  customerId        String          @map("customer_id") @db.Uuid
  name              String
  code              String?
  businessDirection String?         @map("business_direction")
  projectStage      String?         @map("project_stage")
  description       String?
  status            String          @default("active")
  extraMetadata     Json?           @map("extra_metadata") @db.JsonB
  createdAt         DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)
  customer          Customer        @relation(fields: [customerId], references: [id], onDelete: Restrict)
  files             File[]
  projectMembers    ProjectMember[]

  @@unique([customerId, code])
  @@index([customerId])
  @@index([projectStage])
  @@index([status])
  @@map("projects")
}

model File {
  id                String             @id @default(uuid()) @db.Uuid
  projectId         String             @map("project_id") @db.Uuid
  originalName      String             @map("original_name")
  storedName        String             @map("stored_name")
  storagePath       String             @map("storage_path")
  mimeType          String?            @map("mime_type")
  extension         String?
  sizeBytes         BigInt?            @map("size_bytes")
  sha256            String?
  category          String?
  industry          String?
  businessDirection String?            @map("business_direction")
  projectStage      String?            @map("project_stage")
  visibility        String             @default("internal")
  importance        String             @default("normal")
  status            String             @default("uploaded")
  version           String             @default("1")
  customerName      String?            @map("customer_name")
  projectName       String?            @map("project_name")
  source            String             @default("upload")
  parseStatus       String             @default("pending") @map("parse_status")
  parseError        String?            @map("parse_error")
  extraMetadata     Json?              @map("extra_metadata") @db.JsonB
  uploadedAt        DateTime           @default(now()) @map("uploaded_at") @db.Timestamptz(6)
  createdAt         DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt         DateTime?          @map("deleted_at") @db.Timestamptz(6)
  project           Project            @relation(fields: [projectId], references: [id], onDelete: Restrict)
  parsedDocuments   ParsedDocument[]
  documentChunks    DocumentChunk[]
  fileTags          FileTag[]

  @@index([projectId])
  @@index([sha256])
  @@index([category])
  @@index([industry])
  @@index([businessDirection])
  @@index([projectStage])
  @@index([visibility])
  @@index([importance])
  @@index([status])
  @@index([parseStatus])
  @@index([createdAt])
  @@index([deletedAt])
  @@map("files")
}

model ParsedDocument {
  id              String          @id @default(uuid()) @db.Uuid
  fileId          String          @map("file_id") @db.Uuid
  parserName      String?         @map("parser_name")
  parserVersion   String?         @map("parser_version")
  contentText     String?         @map("content_text")
  contentJson     Json?           @map("content_json") @db.JsonB
  summary         String?
  pageCount       Int?            @map("page_count")
  wordCount       Int?            @map("word_count")
  charCount       Int?            @map("char_count")
  language        String?
  status          String          @default("success")
  errorMessage    String?         @map("error_message")
  isLatest        Boolean         @default(true) @map("is_latest")
  parsedAt        DateTime        @default(now()) @map("parsed_at") @db.Timestamptz(6)
  createdAt       DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  file            File            @relation(fields: [fileId], references: [id], onDelete: Cascade)
  documentChunks  DocumentChunk[]

  @@index([fileId])
  @@index([status])
  @@index([isLatest])
  @@index([parsedAt])
  @@map("parsed_documents")
}

model DocumentChunk {
  id               String          @id @default(uuid()) @db.Uuid
  fileId           String          @map("file_id") @db.Uuid
  parsedDocumentId String?         @map("parsed_document_id") @db.Uuid
  chunkIndex       Int             @map("chunk_index")
  contentText      String?         @map("content_text")
  contentJson      Json?           @map("content_json") @db.JsonB
  pageStart        Int?            @map("page_start")
  pageEnd          Int?            @map("page_end")
  tokenCount       Int?            @map("token_count")
  charCount        Int?            @map("char_count")
  embeddingModel   String?         @map("embedding_model")
  embeddingJson    Json?           @map("embedding_json") @db.JsonB
  extraMetadata    Json?           @map("extra_metadata") @db.JsonB
  createdAt        DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  file             File            @relation(fields: [fileId], references: [id], onDelete: Cascade)
  parsedDocument   ParsedDocument? @relation(fields: [parsedDocumentId], references: [id], onDelete: SetNull)

  @@unique([fileId, chunkIndex])
  @@index([fileId])
  @@index([parsedDocumentId])
  @@map("document_chunks")
}

model Tag {
  id          String    @id @default(uuid()) @db.Uuid
  name        String
  slug        String    @unique
  color       String?
  description String?
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  fileTags    FileTag[]

  @@map("tags")
}

model FileTag {
  fileId    String   @map("file_id") @db.Uuid
  tagId     String   @map("tag_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  file      File     @relation(fields: [fileId], references: [id], onDelete: Cascade)
  tag       Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([fileId, tagId])
  @@index([tagId])
  @@map("file_tags")
}

model User {
  id            String          @id @default(uuid()) @db.Uuid
  authUserId    String?         @unique @map("auth_user_id") @db.Uuid
  email         String          @unique
  name          String?
  passwordHash  String?         @map("password_hash")
  status        String          @default("active")
  extraMetadata Json?           @map("extra_metadata") @db.JsonB
  lastLoginAt   DateTime?       @map("last_login_at") @db.Timestamptz(6)
  disabledAt    DateTime?       @map("disabled_at") @db.Timestamptz(6)
  createdByUserId String?       @map("created_by_user_id") @db.Uuid
  updatedByUserId String?       @map("updated_by_user_id") @db.Uuid
  createdAt     DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)
  userRoles     UserRole[]
  projectMembers ProjectMember[]
  createdBy     User?           @relation("UserCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedBy     User?           @relation("UserUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  createdUsers  User[]          @relation("UserCreatedBy")
  updatedUsers  User[]          @relation("UserUpdatedBy")

  @@index([status])
  @@index([createdByUserId])
  @@index([updatedByUserId])
  @@map("users")
}

model Role {
  id              String           @id @default(uuid()) @db.Uuid
  name            String
  slug            String           @unique
  description     String?
  createdAt       DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  rolePermissions RolePermission[]
  userRoles       UserRole[]

  @@map("roles")
}

model Permission {
  id              String           @id @default(uuid()) @db.Uuid
  action          String
  resource        String
  description     String?
  createdAt       DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  rolePermissions RolePermission[]

  @@unique([action, resource])
  @@map("permissions")
}

model RolePermission {
  roleId       String     @map("role_id") @db.Uuid
  permissionId String     @map("permission_id") @db.Uuid
  createdAt    DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([permissionId])
  @@map("role_permissions")
}

model UserRole {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  roleId    String   @map("role_id") @db.Uuid
  scopeType String   @default("global") @map("scope_type")
  scopeId   String?  @map("scope_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId, scopeType, scopeId])
  @@index([roleId])
  @@index([scopeType, scopeId])
  @@map("user_roles")
}

model ProjectMember {
  projectId String   @map("project_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  roleSlug  String   @map("role_slug")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([projectId, userId])
  @@index([userId])
  @@index([roleSlug])
  @@map("project_members")
}
